<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard — Admin PT. Trimas Mitra Perkasa</title>
    <link href="/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="/css/admin.css" rel="stylesheet">
</head>
<body>

<div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>
<div class="mobile-admin-topbar">
    <div class="mobile-topbar-left">
        <button class="sidebar-toggle-btn" onclick="openSidebar()"><i class="fa-solid fa-bars"></i></button>
        <span class="mobile-topbar-title">Dashboard</span>
    </div>
    <div class="mobile-topbar-avatar"><i class="fa-solid fa-user-tie"></i></div>
</div>

<!-- SIDEBAR -->
<aside class="admin-sidebar">
    <div class="sidebar-header">
        <div class="sidebar-logo">
            <div class="sidebar-logo-icon"><i class="fa-solid fa-server"></i></div>
            <div>
                <div class="sidebar-brand">Admin Panel</div>
                <div class="sidebar-brand-sub">PT. Trimas Mitra Perkasa</div>
            </div>
        </div>
    </div>
    <nav class="sidebar-nav">
        <span class="nav-label">Utama</span>
        <a href="/admin/dashboard" class="nav-link active"><i class="fa-solid fa-gauge-high"></i> Dashboard</a>
        <span class="nav-label">Manajemen</span>
        <a href="/admin/requests" class="nav-link">
            <i class="fa-solid fa-file-invoice-dollar"></i> Permintaan Penawaran
            <% if (pendingOrders > 0) { %><span class="nav-badge"><%= pendingOrders %></span><% } %>
        </a>
        <a href="/admin/products" class="nav-link"><i class="fa-solid fa-boxes-stacked"></i> Katalog Produk</a>
        <a href="/admin/customers" class="nav-link"><i class="fa-solid fa-users"></i> Daftar Pelanggan</a>
    </nav>
    <div class="sidebar-footer">
        <div class="admin-user-card">
            <div class="admin-avatar"><i class="fa-solid fa-user-tie"></i></div>
            <div>
                <div class="admin-user-name"><%= adminName %></div>
                <div class="admin-user-role">Administrator</div>
            </div>
        </div>
        <a href="/admin-logout" class="btn-logout"><i class="fa-solid fa-right-from-bracket"></i> Logout System</a>
    </div>
</aside>

<!-- MAIN -->
<div class="admin-main">
    <div class="admin-topbar">
        <div class="topbar-left">
            <span class="topbar-page">Dashboard Overview</span>
        </div>
        <div class="topbar-right">
            <div class="topbar-clock">
                <i class="fa-regular fa-clock"></i>
                <span id="clock"></span>
            </div>
            <a href="/admin/products/add" class="btn-accent" style="font-size:0.82rem;padding:0.45rem 0.9rem;">
                <i class="fa-solid fa-plus"></i> Tambah Produk
            </a>
        </div>
    </div>

    <div class="admin-content">
        <div class="page-header">
            <div>
                <div class="page-overline">OVERVIEW</div>
                <h1 class="page-title">Dashboard</h1>
                <p class="page-sub">Ringkasan aktivitas sistem hari ini.</p>
            </div>
        </div>

        <!-- Stat Cards -->
        <div class="row g-3 mb-4">
            <div class="col-sm-6 col-lg-3">
                <div class="stat-card card-orange">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="stat-label">Pending RFQ</div>
                            <div class="stat-value"><%= pendingOrders %></div>
                            <div class="stat-note"><%= pendingOrders > 0 ? 'Perlu ditindaklanjuti' : 'Tidak ada antrian' %></div>
                        </div>
                        <div class="stat-icon"><i class="fa-solid fa-hourglass-half"></i></div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="stat-card card-blue">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="stat-label">Total Produk</div>
                            <div class="stat-value"><%= totalProducts %></div>
                            <div class="stat-note">SKU dalam katalog</div>
                        </div>
                        <div class="stat-icon"><i class="fa-solid fa-boxes-stacked"></i></div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="stat-card card-green">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="stat-label">Pelanggan</div>
                            <div class="stat-value"><%= typeof totalCustomers !== 'undefined' ? totalCustomers : '—' %></div>
                            <div class="stat-note">Mitra terdaftar</div>
                        </div>
                        <div class="stat-icon"><i class="fa-solid fa-users"></i></div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <a href="/admin/requests?status=pending" style="text-decoration:none;">
                    <div class="stat-card card-purple" style="cursor:pointer;">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <div class="stat-label">Aksi Cepat</div>
                                <div style="margin-top:0.5rem;">
                                    <span style="font-size:0.85rem;font-weight:700;color:#fff;display:flex;align-items:center;gap:0.35rem;">
                                        <i class="fa-solid fa-arrow-right"></i> Proses RFQ
                                    </span>
                                </div>
                            </div>
                            <div class="stat-icon"><i class="fa-solid fa-bolt"></i></div>
                        </div>
                    </div>
                </a>
            </div>
        </div>

        <!-- Recent Orders -->
        <div class="data-card">
            <div class="data-card-header">
                <h6 class="data-card-title">
                    <i class="fa-solid fa-clock-rotate-left" style="color:var(--muted);"></i>
                    Permintaan Penawaran Terbaru
                    <% if (pendingOrders > 0) { %>
                        <span class="badge-pill badge-pending" style="font-size:0.68rem;"><%= pendingOrders %> pending</span>
                    <% } %>
                </h6>
                <a href="/admin/requests" class="btn-ghost" style="font-size:0.8rem;padding:0.38rem 0.8rem;">
                    Lihat Semua <i class="fa-solid fa-arrow-right ms-1"></i>
                </a>
            </div>
            <div class="data-table table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Order ID</th>
                            <th>Pelanggan</th>
                            <th>Tanggal</th>
                            <th>Status</th>
                            <th style="text-align:right;">Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (recentOrders.length > 0) { %>
                            <% recentOrders.forEach(order => { %>
                                <tr class="<%= order.Order_Status === 'Pending Review' ? 'row-urgent' : '' %>">
                                    <td style="font-weight:700;color:var(--steel);">REQ-<%= order.Order_ID %></td>
                                    <td>
                                        <div style="font-weight:600;color:var(--text)"><%= order.Company_Name %></div>
                                    </td>
                                    <td style="color:var(--muted);font-size:0.845rem;">
                                        <%= new Date(order.Order_Date).toLocaleDateString('id-ID', {day:'2-digit',month:'short',year:'numeric'}) %>
                                    </td>
                                    <td>
                                        <% if (order.Order_Status === 'Pending Review') { %>
                                            <span class="badge-pill badge-pending"><i class="fa-solid fa-circle" style="font-size:0.4rem;"></i><%= order.Order_Status %></span>
                                        <% } else { %>
                                            <span class="badge-pill badge-done"><i class="fa-solid fa-circle" style="font-size:0.4rem;"></i><%= order.Order_Status %></span>
                                        <% } %>
                                    </td>
                                    <td style="text-align:right;">
                                        <a href="/admin/requests/<%= order.Order_ID %>" class="btn-primary" style="font-size:0.78rem;padding:0.38rem 0.8rem;">
                                            Proses <i class="fa-solid fa-arrow-right ms-1"></i>
                                        </a>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="5" style="text-align:center;padding:3rem;color:var(--muted);">
                                    <i class="fa-solid fa-inbox" style="font-size:2rem;opacity:0.15;display:block;margin-bottom:0.6rem;"></i>
                                    Belum ada permintaan masuk.
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<nav class="admin-bottom-nav">
    <a href="/admin/dashboard" class="admin-bnav-item active"><i class="fa-solid fa-gauge-high"></i><span>Dashboard</span></a>
    <a href="/admin/requests" class="admin-bnav-item">
        <i class="fa-solid fa-file-invoice-dollar"></i><span>Penawaran</span>
        <% if (pendingOrders > 0) { %><span class="admin-bnav-badge"><%= pendingOrders %></span><% } %>
    </a>
    <a href="/admin/products" class="admin-bnav-item"><i class="fa-solid fa-boxes-stacked"></i><span>Produk</span></a>
    <a href="/admin/customers" class="admin-bnav-item"><i class="fa-solid fa-users"></i><span>Pelanggan</span></a>
</nav>

<script src="/js/bootstrap.bundle.min.js"></script>
<script>
    function updateClock() {
        document.getElementById('clock').innerText = new Date().toLocaleTimeString('id-ID');
    }
    updateClock();
    setInterval(updateClock, 1000);
    function openSidebar() {
        document.querySelector('.admin-sidebar').classList.add('open');
        document.getElementById('sidebarOverlay').classList.add('active');
        document.body.style.overflow = 'hidden';
    }
    function closeSidebar() {
        document.querySelector('.admin-sidebar').classList.remove('open');
        document.getElementById('sidebarOverlay').classList.remove('active');
        document.body.style.overflow = '';
    }
</script>
</body>
</html>
