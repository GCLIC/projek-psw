<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Katalog Produk — Admin PT. Trimas Mitra Perkasa</title>
    <link href="/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="/css/admin.css" rel="stylesheet">
</head>
<body>

<aside class="admin-sidebar">
    <div class="sidebar-header">
        <div class="sidebar-logo">
            <div class="sidebar-logo-icon"><i class="fa-solid fa-server"></i></div>
            <div>
                <div class="sidebar-brand">Admin Panel</div>
                <div class="sidebar-brand-sub">PT. Trimas Mitra Perkasa</div>
            </div>
        </div>
    </div>
    <nav class="sidebar-nav">
        <span class="nav-label">Utama</span>
        <a href="/admin/dashboard" class="nav-link"><i class="fa-solid fa-gauge-high"></i> Dashboard</a>
        <span class="nav-label">Manajemen</span>
        <a href="/admin/requests" class="nav-link"><i class="fa-solid fa-file-invoice-dollar"></i> Permintaan Penawaran</a>
        <a href="/admin/products" class="nav-link active"><i class="fa-solid fa-boxes-stacked"></i> Katalog Produk</a>
        <a href="/admin/customers" class="nav-link"><i class="fa-solid fa-users"></i> Daftar Pelanggan</a>
    </nav>
    <div class="sidebar-footer">
        <div class="admin-user-card">
            <div class="admin-avatar"><i class="fa-solid fa-user-tie"></i></div>
            <div>
                <div class="admin-user-name"><%= adminName %></div>
                <div class="admin-user-role">Administrator</div>
            </div>
        </div>
        <a href="/admin-logout" class="btn-logout"><i class="fa-solid fa-right-from-bracket"></i> Logout System</a>
    </div>
</aside>

<div class="admin-main">
    <div class="admin-topbar">
        <div class="topbar-left">
            <div class="topbar-breadcrumb">
                <a href="/admin/dashboard">Dashboard</a>
                <span class="sep">/</span>
            </div>
            <span class="topbar-page">Katalog Produk</span>
        </div>
        <div class="topbar-right">
            <a href="/admin/products/add" class="btn-accent" style="font-size:0.82rem;padding:0.45rem 0.9rem;">
                <i class="fa-solid fa-plus"></i> Tambah Produk
            </a>
        </div>
    </div>

    <div class="admin-content">
        <div class="page-header">
            <div>
                <div class="page-overline">MANAJEMEN KATALOG</div>
                <h1 class="page-title">Katalog Produk</h1>
                <p class="page-sub">Kelola stok, harga acuan, dan spesifikasi produk. Total: <strong style="color:var(--primary);"><%= products.length %> SKU</strong></p>
            </div>
            <div class="search-wrap" style="width:260px;">
                <span class="search-icon"><i class="fa-solid fa-magnifying-glass"></i></span>
                <input type="text" id="productSearch" class="search-input" placeholder="Cari nama produk...">
            </div>
        </div>

        <div class="data-card">
            <div class="data-table table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th style="width:5%;">SKU</th>
                            <th style="width:42%;">Produk</th>
                            <th style="width:13%;text-align:center;">Stok</th>
                            <th style="width:18%;text-align:right;">Harga Acuan</th>
                            <th style="width:22%;text-align:center;">Aksi</th>
                        </tr>
                    </thead>
                    <tbody id="productTableBody">
                        <% if (products.length > 0) { %>
                            <% products.forEach(product => { %>
                                <tr>
                                    <td>
                                        <span style="font-size:0.75rem;font-weight:700;color:var(--muted);font-variant-numeric:tabular-nums;">
                                            #<%= String(product.Product_ID).padStart(3,'0') %>
                                        </span>
                                    </td>
                                    <td>
                                        <div style="display:flex;align-items:center;gap:0.75rem;padding:0.15rem 0;">
                                            <% if (product.Img_Url) { %>
                                                <img src="/images/<%= encodeURIComponent(product.Img_Url) %>"
                                                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
                                                     style="width:36px;height:36px;border-radius:8px;object-fit:cover;border:1px solid var(--border);flex-shrink:0;">
                                                <div style="display:none;width:36px;height:36px;background:var(--bg);border:1px solid var(--border);border-radius:8px;align-items:center;justify-content:center;flex-shrink:0;color:var(--muted);font-size:0.9rem;">
                                                    <i class="fa-solid fa-box-open"></i>
                                                </div>
                                            <% } else { %>
                                                <div style="width:36px;height:36px;background:var(--bg);border:1px solid var(--border);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;color:var(--muted);font-size:0.9rem;">
                                                    <i class="fa-solid fa-box-open"></i>
                                                </div>
                                            <% } %>
                                            <div>
                                                <div style="font-weight:700;color:var(--primary);font-size:0.875rem;line-height:1.3;" class="product-name"><%= product.Product_Name %></div>
                                                <div style="font-size:0.75rem;color:var(--muted);max-width:280px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;margin-top:0.1rem;"><%= product.Short_Desc || '—' %></div>
                                            </div>
                                        </div>
                                    </td>
                                    <td style="text-align:center;">
                                        <% if (product.Stock > 10) { %>
                                            <span class="stock-badge stock-ok"><%= product.Stock %></span>
                                        <% } else if (product.Stock > 0) { %>
                                            <span class="stock-badge stock-low"><%= product.Stock %> ⚠</span>
                                        <% } else { %>
                                            <span class="stock-badge stock-out">Habis</span>
                                        <% } %>
                                    </td>
                                    <td style="text-align:right;font-weight:700;color:var(--text);font-size:0.875rem;font-variant-numeric:tabular-nums;">
                                        <% if (product.Unit_Price > 0) { %>
                                            <span style="font-size:0.7rem;font-weight:600;color:var(--muted);">Rp</span>
                                            <%= Number(product.Unit_Price).toLocaleString('id-ID') %>
                                        <% } else { %>
                                            <span style="color:var(--muted);font-weight:400;">—</span>
                                        <% } %>
                                    </td>
                                    <td style="text-align:center;">
                                        <div style="display:flex;justify-content:center;align-items:center;gap:0.4rem;">
                                            <a href="/admin/products/edit/<%= product.Product_ID %>" class="btn-icon edit" title="Edit Produk">
                                                <i class="fa-solid fa-pen"></i>
                                            </a>
                                            <form action="/admin/products/delete/<%= product.Product_ID %>" method="POST"
                                                  onsubmit="return confirm('Hapus produk ini?\n\n<%= product.Product_Name %>\n\nTindakan ini tidak bisa dibatalkan.');"
                                                  style="margin:0;">
                                                <button type="submit" class="btn-icon del" title="Hapus Produk">
                                                    <i class="fa-solid fa-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="5" style="text-align:center;padding:4rem;color:var(--muted);">
                                    <i class="fa-solid fa-boxes-stacked" style="font-size:2.5rem;opacity:0.15;display:block;margin-bottom:0.75rem;"></i>
                                    <div style="font-weight:600;margin-bottom:0.35rem;">Katalog masih kosong</div>
                                    <a href="/admin/products/add" class="btn-accent" style="font-size:0.82rem;padding:0.45rem 0.9rem;display:inline-flex;margin-top:0.5rem;">
                                        <i class="fa-solid fa-plus"></i> Tambah Produk Pertama
                                    </a>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script src="/js/bootstrap.bundle.min.js"></script>
<script>
    document.getElementById('productSearch').addEventListener('input', function() {
        const q = this.value.toLowerCase();
        document.querySelectorAll('#productTableBody tr').forEach(row => {
            const n = row.querySelector('.product-name');
            row.style.display = (!n || n.textContent.toLowerCase().includes(q)) ? '' : 'none';
        });
    });
</script>
</body>
</html>
